# Copy this file to .env and set a local lab password.
# Do not commit .env.

# Use an official Splunk image tag that exists for your platform.
# Pin to a specific version or digest for repeatable labs.
SPLUNK_IMAGE=splunk/splunk:10.2
UF_IMAGE=splunk/universalforwarder:10.2

# Compose project name controls generated container/network names. Change this
# if you want to run multiple clones of the lab on the same Docker host.
COMPOSE_PROJECT_NAME=learn-splunk

# Splunk Docker images are commonly amd64-only. On Apple Silicon, Docker Desktop
# can run them under emulation with this platform setting.
SPLUNK_PLATFORM=linux/amd64

# Docker socket used by the browser Lab CLI. Docker Desktop and Linux usually
# expose /var/run/docker.sock. Override only if your Docker installation uses a
# different socket path.
DOCKER_SOCKET=/var/run/docker.sock

# Must meet Splunk password requirements.
SPLUNK_PASSWORD=change-this-local-lab-password

# Required for Splunk Enterprise 10.x and later after reviewing Splunk General Terms.
SPLUNK_GENERAL_TERMS=--accept-sgt-current-at-splunk-com

# Host ports. Change these if a port is already used on your machine.
LESSON_WEB_PORT=3000
SPLUNK_WEB_PORT=8000
SPLUNK_HEC_PORT=8088
SPLUNK_MANAGEMENT_PORT=8089
SPLUNK_RECEIVING_PORT=9997
DEPLOYMENT_WEB_PORT=18000
DEPLOYMENT_MANAGEMENT_PORT=18089
HEAVY_WEB_PORT=28000
HEAVY_TCP_PORT=1514
MCP_BIND_HOST=127.0.0.1
MCP_PORT=8050
SPLUNK_CONNECT_RETRIES=30
SPLUNK_CONNECT_RETRY_MS=10000

