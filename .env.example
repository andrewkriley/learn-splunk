# Copy this file to .env and set a local lab password.
# Do not commit .env.

# Use an official Splunk image tag that exists for your platform.
# Pin to a specific version or digest for repeatable labs.
SPLUNK_IMAGE=splunk/splunk:10.2
UF_IMAGE=splunk/universalforwarder:10.2

# Splunk Docker images are commonly amd64-only. On Apple Silicon, Docker Desktop
# can run them under emulation with this platform setting.
SPLUNK_PLATFORM=linux/amd64

# Docker Desktop on macOS often uses this socket path.
# Linux users can leave this unset or set /var/run/docker.sock.
DOCKER_SOCKET=/Users/andreril/.docker/run/docker.sock

# Must meet Splunk password requirements.
SPLUNK_PASSWORD=change-this-local-lab-password

# Required for Splunk Enterprise 10.x and later after reviewing Splunk General Terms.
SPLUNK_GENERAL_TERMS=--accept-sgt-current-at-splunk-com

